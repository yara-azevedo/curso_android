<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Fundo escuro -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#0B0F14" />
        </shape>
    </item>

    <!-- Brilho rosa no canto superior esquerdo -->
    <item android:gravity="top|left">
        <shape android:shape="rectangle">
            <size android:width="340dp" android:height="340dp" />
            <gradient
                android:type="radial"
                android:gradientRadius="250dp"
                android:startColor="#00BCD4"
                android:endColor="#00FFFFFF"
                android:centerX="0.3"
                android:centerY="0.3" />
        </shape>
    </item>

    <!-- Brilho verde no canto inferior direito -->
    <item android:gravity="bottom|right">
        <shape android:shape="rectangle">
            <size android:width="380dp" android:height="380dp" />
            <gradient
                android:type="radial"
                android:gradientRadius="280dp"
                android:startColor="#1832D1"
                android:endColor="#00FFFFFF"
                android:centerX="0.7"
                android:centerY="0.7" />
        </shape>
    </item>

</layer-list>
